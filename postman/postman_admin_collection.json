{
  "info": {
    "name": "Gallery API Admin Auto-Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001", "type": "string" },
    { "key": "adminEmail", "value": "admin@mail.ru", "type": "string" },
    { "key": "adminPassword", "value": "Password123!", "type": "string" },
    { "key": "adminAccessToken", "value": "", "type": "string" },
    { "key": "dummyEmail", "value": "", "type": "string" },
    { "key": "dummyPassword", "value": "TestPass123!", "type": "string" },
    { "key": "dummyUserId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Login as Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var jsonData = pm.response.json();",
              "if (jsonData.accessToken) {",
              "    pm.collectionVariables.set(\"adminAccessToken\", jsonData.accessToken);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [ "{{baseUrl}}" ],
          "path": [ "auth", "login" ]
        }
      }
    },
    {
      "name": "2. Create Dummy User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var randomNum = Math.floor(Math.random() * 100000);",
              "pm.collectionVariables.set(\"dummyEmail\", \"dummy_\" + randomNum + \"@mail.ru\");"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{dummyEmail}}\",\n  \"password\": \"{{dummyPassword}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/signup",
          "host": [ "{{baseUrl}}" ],
          "path": [ "auth", "signup" ]
        }
      }
    },
    {
      "name": "3. Get All Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has node array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.node).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{adminAccessToken}}", "type": "string" } ] },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users?pageNo=1&perPage=10",
          "host": [ "{{baseUrl}}" ],
          "path": [ "users" ],
          "query": [
            { "key": "pageNo", "value": "1" },
            { "key": "perPage", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "4. Get User by Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Email matches dummy user\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.login).to.eql(pm.collectionVariables.get(\"dummyEmail\"));",
              "    pm.collectionVariables.set(\"dummyUserId\", jsonData.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{adminAccessToken}}", "type": "string" } ] },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{dummyEmail}}",
          "host": [ "{{baseUrl}}" ],
          "path": [ "users", "{{dummyEmail}}" ]
        }
      }
    },
    {
      "name": "5. Get User Images (Admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has node array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.node).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{adminAccessToken}}", "type": "string" } ] },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/store/admin/image/{{dummyUserId}}?pageNo=1&perPage=10",
          "host": [ "{{baseUrl}}" ],
          "path": [ "store", "admin", "image", "{{dummyUserId}}" ],
          "query": [
            { "key": "pageNo", "value": "1" },
            { "key": "perPage", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "6. Block User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Success is true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{adminAccessToken}}", "type": "string" } ] },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{dummyEmail}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/users/block",
          "host": [ "{{baseUrl}}" ],
          "path": [ "users", "block" ]
        }
      }
    },
    {
      "name": "7. Delete User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Success is true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{adminAccessToken}}", "type": "string" } ] },
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{dummyEmail}}",
          "host": [ "{{baseUrl}}" ],
          "path": [ "users", "{{dummyEmail}}" ]
        }
      }
    }
  ]
}
