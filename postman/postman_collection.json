{
  "info": {
    "name": "Gallery API Auto-Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "testEmail", "value": "autotest@mail.ru", "type": "string" },
    { "key": "testPassword", "value": "Password123!", "type": "string" },
    { "key": "imageId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Sign Up",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var randomNum = Math.floor(Math.random() * 10000);",
                  "pm.collectionVariables.set(\"testEmail\", \"user\" + randomNum + \"@mail.ru\");"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "signup" ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "login" ]
            }
          }
        }
      ]
    },
    {
      "name": "1.1 Auth Validations (Negative)",
      "item": [
        {
          "name": "Sign Up - Invalid Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test(\"Check error message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var msgs = JSON.stringify(jsonData.message);",
                  "    pm.expect(msgs).to.include(\"LOGIN_IS_NOT_VALID_FORMAT\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"invalid-email-format\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "signup" ]
            }
          }
        },
        {
          "name": "Sign Up - Password Too Short",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test(\"Check error message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var msgs = JSON.stringify(jsonData.message);",
                  "    pm.expect(msgs).to.include(\"PASSWORD_INVALID_LENGTH\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"test_short@mail.ru\",\n  \"password\": \"Pass1!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "signup" ]
            }
          }
        },
        {
          "name": "Sign Up - Password Too Long",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test(\"Check error message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var msgs = JSON.stringify(jsonData.message);",
                  "    pm.expect(msgs).to.include(\"PASSWORD_INVALID_LENGTH\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"test_long@mail.ru\",\n  \"password\": \"VeryLongPassword1234567890!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "signup" ]
            }
          }
        },
        {
          "name": "Sign Up - Password Invalid Format",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test(\"Check error message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var msgs = JSON.stringify(jsonData.message);",
                  "    pm.expect(msgs).to.include(\"PASSWORD_IS_NOT_VALID_FORMAT\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"test_format@mail.ru\",\n  \"password\": \"Password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "signup" ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Users",
      "item": [
        {
          "name": "Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Email matches\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.login).to.eql(pm.collectionVariables.get(\"testEmail\"));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": [ "{{baseUrl}}" ],
              "path": [ "users", "profile" ]
            }
          }
        },
        {
          "name": "Update Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Name updated\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.firstName).to.eql(\"Auto\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Auto\",\n  \"lastName\": \"Test\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/users/profile",
              "host": [ "{{baseUrl}}" ],
              "path": [ "users", "profile" ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Store",
      "item": [
        {
          "name": "Upload Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Test Image", "type": "text" },
                { "key": "author", "value": "Auto Tester", "type": "text" },
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/store/upload",
              "host": [ "{{baseUrl}}" ],
              "path": [ "store", "upload" ]
            }
          }
        },
        {
          "name": "Get Images",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.node && jsonData.node.length > 0) {",
                  "    pm.collectionVariables.set(\"imageId\", jsonData.node[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/store/image",
              "host": [ "{{baseUrl}}" ],
              "path": [ "store", "image" ]
            }
          }
        },
        {
          "name": "Update Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{imageId}}\",\n  \"title\": \"Updated Title\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/store/update",
              "host": [ "{{baseUrl}}" ],
              "path": [ "store", "update" ]
            }
          }
        },
        {
          "name": "Delete Image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "method": "DELETE",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{imageId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/store/image",
              "host": [ "{{baseUrl}}" ],
              "path": [ "store", "image" ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Auth (Refresh & Logout)",
      "item": [
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "refresh" ]
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{accessToken}}", "type": "string" } ] },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "logout" ]
            }
          }
        }
      ]
    }
  ]
}
